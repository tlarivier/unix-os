/*
 * errno.def - X-macro definitions for all errno values
 * 
 * Format: ERRNO_X(name, value, message)
 * 
 * Usage:
 *   #define ERRNO_X(name, val, msg) ...
 *   #include "errno.def"
 *   #undef ERRNO_X
 */

/* Success */
ERRNO_X(EOK,             0,   "Success")

/* POSIX standard errors */
ERRNO_X(EPERM,           1,   "Operation not permitted")
ERRNO_X(ENOENT,          2,   "No such file or directory")
ERRNO_X(ESRCH,           3,   "No such process")
ERRNO_X(EINTR,           4,   "Interrupted system call")
ERRNO_X(EIO,             5,   "I/O error")
ERRNO_X(ENXIO,           6,   "No such device or address")
ERRNO_X(E2BIG,           7,   "Argument list too long")
ERRNO_X(ENOEXEC,         8,   "Exec format error")
ERRNO_X(EBADF,           9,   "Bad file descriptor")
ERRNO_X(ECHILD,         10,   "No child processes")
ERRNO_X(EAGAIN,         11,   "Resource temporarily unavailable")
ERRNO_X(ENOMEM,         12,   "Cannot allocate memory")
ERRNO_X(EACCES,         13,   "Permission denied")
ERRNO_X(EFAULT,         14,   "Bad address")
ERRNO_X(ENOTBLK,        15,   "Block device required")
ERRNO_X(EBUSY,          16,   "Device or resource busy")
ERRNO_X(EEXIST,         17,   "File exists")
ERRNO_X(EXDEV,          18,   "Invalid cross-device link")
ERRNO_X(ENODEV,         19,   "No such device")
ERRNO_X(ENOTDIR,        20,   "Not a directory")
