/* Process management */
SYSCALL_X(exit,         1,  1)
SYSCALL_X(fork,         2,  0)
SYSCALL_X(waitpid,      3,  3)
SYSCALL_X(getpid,       4,  0)
SYSCALL_X(getppid,      5,  0)
SYSCALL_X(execve,       7,  3)

/* File I/O */
SYSCALL_X(read,        10,  3)
SYSCALL_X(write,       11,  3)
SYSCALL_X(open,        12,  3)
SYSCALL_X(close,       13,  1)
SYSCALL_X(lseek,       14,  3)
SYSCALL_X(dup,         15,  1)
SYSCALL_X(dup2,        16,  2)
SYSCALL_X(pipe,        17,  1)

/* Filesystem */
SYSCALL_X(stat,        20,  2)
SYSCALL_X(fstat,       21,  2)
SYSCALL_X(mkdir,       22,  2)
SYSCALL_X(rmdir,       23,  1)
SYSCALL_X(unlink,      24,  1)
SYSCALL_X(rename,      25,  2)
SYSCALL_X(chmod,       26,  2)
SYSCALL_X(chown,       27,  3)
/* link: declared but unwired — sys_link is not implemented; calls return -ENOSYS. */
SYSCALL_X(link,        28,  2)

/* Directory */
SYSCALL_X(getdents,    30,  3)
SYSCALL_X(chdir,       31,  1)
SYSCALL_X(getcwd,      32,  2)

/* Memory */
SYSCALL_X(brk,         40,  1)
/* mmap: 6-arg POSIX takes (addr,len,prot,flags,fd,offset); our INT 0x80 ABI
 * only passes 5 args (EBX..EDI), so file-backed mappings start at offset 0. */
SYSCALL_X(mmap,        41,  5)
SYSCALL_X(munmap,      42,  2)
SYSCALL_X(mprotect,    43,  3)

/* Signals */
SYSCALL_X(signal,      50,  2)
SYSCALL_X(kill,        51,  2)

/* Time */
SYSCALL_X(time,        60,  1)
SYSCALL_X(nanosleep,   61,  2)
SYSCALL_X(gettimeofday,62,  2)
SYSCALL_X(clock_gettime,63, 2)

/* System info */
SYSCALL_X(getuid,      71,  0)
SYSCALL_X(getgid,      72,  0)
SYSCALL_X(geteuid,     73,  0)
SYSCALL_X(getegid,     74,  0)
SYSCALL_X(setuid,      75,  1)
SYSCALL_X(getrlimit,   76,  2)
SYSCALL_X(setrlimit,   77,  2)
SYSCALL_X(nice,        78,  1)
SYSCALL_X(setgid,      80,  1)
SYSCALL_X(seteuid,     81,  1)
SYSCALL_X(setegid,     106, 1)

/* Job control */
SYSCALL_X(setpgid,     84,  2)
SYSCALL_X(getpgid,     85,  1)
SYSCALL_X(getpgrp,     86,  0)
SYSCALL_X(setsid,      87,  0)
SYSCALL_X(getsid,      88,  1)
SYSCALL_X(tcgetpgrp,   89,  1)
SYSCALL_X(tcsetpgrp,   90,  2)

/* Terminal */
SYSCALL_X(tcgetattr,   91,  2)
SYSCALL_X(tcsetattr,   92,  3)
SYSCALL_X(isatty,      93,  1)
SYSCALL_X(ttyname,     94,  3)

/* OS extensions */
SYSCALL_X(reboot,     100,  1)
SYSCALL_X(truncate,   103,  2)
SYSCALL_X(ftruncate,  104,  2)

/* Threading */
SYSCALL_X(set_tid_address, 222, 1)
SYSCALL_X(gettid,     223, 0)

SYSCALL_X(gfx_mode,      245, 1)
SYSCALL_X(gfx_palette,   246, 3)

SYSCALL_X(kb_event,      247, 1)
